@model IEnumerable<SQL_Web_Management.Domain.Entities.ConnectionProfile>
@{
    ViewData["Title"] = "Ulanishlar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">SQL Server ulanishlari</h1>
        <p class="text-muted mb-0">Serverlaringizni saqlang va workspace oching</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ Yangi ulanish</a>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger" style="white-space: pre-wrap;">@error</div>
}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nomi</th>
                    <th>Server</th>
                    <th>Database</th>
                    <th>Auth</th>
                    <th>Username</th>
                    <th>Oxirgi ishlatilgan</th>
                    <th class="text-end">Amallar</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            Hali ulanish yo'q. Birinchi SQL Server ulanishingizni qo'shing.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td>@item.Server</td>
                            <td>@item.Database</td>
                            <td>@(item.AuthenticationType == SQL_Web_Management.Domain.Enums.AuthenticationType.Windows ? "Windows" : "SQL Server")</td>
                            <td>@(item.AuthenticationType == SQL_Web_Management.Domain.Enums.AuthenticationType.Windows ? "—" : item.Username)</td>
                            <td>@(item.LastUseAt?.ToLocalTime().ToString("g") ?? "—")</td>
                            <td class="text-end">
                                <a asp-controller="Workspace" asp-action="Index" asp-route-id="@item.Id" class="btn btn-sm btn-success">Ochish</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Tahrirlash</a>
                                <form asp-action="Test" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Test</button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Ulanish o\'chirilsinmi?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">O'chirish</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
