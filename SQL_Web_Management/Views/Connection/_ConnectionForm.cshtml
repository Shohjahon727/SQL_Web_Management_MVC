@using SQL_Web_Management.Domain.Enums
@model ConnectionFormViewModel

<form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" method="post" id="connectionForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="Masalan: Local Dev" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Server" class="form-label"></label>
            <input asp-for="Server" class="form-control" placeholder="localhost, (localdb)\MSSQLLocalDB" />
            <span asp-validation-for="Server" class="text-danger"></span>
            <div class="form-text">Default: localhost | LocalDB: (localdb)\MSSQLLocalDB</div>
        </div>
        <div class="col-md-6">
            <label asp-for="Database" class="form-label"></label>
            <input asp-for="Database" class="form-control" />
            <span asp-validation-for="Database" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="AuthenticationType" class="form-label"></label>
            <select asp-for="AuthenticationType" class="form-select" id="authType"
                    asp-items="Html.GetEnumSelectList<AuthenticationType>()"></select>
        </div>
        <div class="col-md-6" id="usernameGroup">
            <label asp-for="Username" class="form-label"></label>
            <input asp-for="Username" class="form-control" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>
        <div class="col-md-6" id="passwordGroup">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger"></span>
            @if (Model.Id != 0)
            {
                <div class="form-text">Parolni o'zgartirmasangiz bo'sh qoldiring.</div>
            }
        </div>
    </div>

    <div id="testResult" class="alert d-none mt-3 mb-0" style="white-space: pre-wrap;"></div>

    <div class="d-flex gap-2 mt-4">
        <button type="button" class="btn btn-outline-primary" id="btnTestConnection">Ulanishni test qilish</button>
        <button type="submit" class="btn btn-primary">Saqlash</button>
        <a asp-action="Index" class="btn btn-link">Bekor qilish</a>
    </div>
</form>